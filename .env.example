# SurakshaNet AI — Environment Variables Template
# Copy this file to .env and fill in your credentials

# ─────────────────────────────────────────────────────────────────
# LLM & Vision Inference
# ─────────────────────────────────────────────────────────────────
# Groq API Key — Get from https://console.groq.com
GROQ_API_KEY=gsk_your_key_here

# ─────────────────────────────────────────────────────────────────
# Relational Database (Supabase PostgreSQL)
# ─────────────────────────────────────────────────────────────────
# Full connection string from Supabase dashboard
DATABASE_URL=postgresql://postgres:password@host:5432/postgres

# ─────────────────────────────────────────────────────────────────
# Graph Database (Neo4j Aura)
# ─────────────────────────────────────────────────────────────────
# Neo4j URI from Aura console (neo4j+s://...)
NEO4J_URI=neo4j+s://your-instance.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_password_here

# ─────────────────────────────────────────────────────────────────
# Caching Layer (Upstash Redis)
# ─────────────────────────────────────────────────────────────────
# Redis URL from Upstash console
UPSTASH_REDIS_URL=rediss://default:password@host:6379

# ─────────────────────────────────────────────────────────────────
# ML Models (Hugging Face)
# ─────────────────────────────────────────────────────────────────
# HF token for downloading embeddings models
HUGGINGFACE_API_KEY=hf_your_token_here

# ─────────────────────────────────────────────────────────────────
# Feature Flags
# ─────────────────────────────────────────────────────────────────
# Set to true to use demo responses instead of real APIs (development)
DEMO_MOCK_MODE=false

# ─────────────────────────────────────────────────────────────────
# Frontend API Base URL (used by Next.js client code)
# ─────────────────────────────────────────────────────────────────
# In development, this is typically http://localhost:8000
# In production, point to your Hugging Face Spaces or Render backend
NEXT_PUBLIC_API_URL=http://localhost:8000
